#!/bin/sh
# configure script - detects libraries and generates config.mk
# Usage: ./configure [options]
#   --cc=COMPILER          Set C compiler (default: gcc)
#   --flint-include=PATH   Set FLINT include path
#   --flint-lib=PATH       Set FLINT library path
#   --pml-include=PATH     Set PML include path
#   --pml-lib=PATH         Set PML library path
#   --enable-asan          Enable AddressSanitizer (ASan) memory checking
#   --disable-asan         Disable AddressSanitizer (default)
#   --help                 Show this help

set -e

# ============================================================
# Defaults
# ============================================================
CC="${CC:-gcc}"
FLINT_INCLUDE_PATH="${FLINT_INCLUDE_PATH:-/usr/local/include}"
FLINT_LIB_PATH="${FLINT_LIB_PATH:-/usr/local/lib}"
PML_INCLUDE_PATH="${PML_INCLUDE_PATH:-/usr/local/include}"
PML_LIB_PATH="${PML_LIB_PATH:-/usr/local/lib}"
ENABLE_ASAN="no"

# ============================================================
# Parse command-line arguments
# ============================================================
for arg in "$@"; do
    case "$arg" in
        --cc=*)            CC="${arg#--cc=}" ;;
        --flint-include=*) FLINT_INCLUDE_PATH="${arg#--flint-include=}" ;;
        --flint-lib=*)     FLINT_LIB_PATH="${arg#--flint-lib=}" ;;
        --pml-include=*)   PML_INCLUDE_PATH="${arg#--pml-include=}" ;;
        --pml-lib=*)       PML_LIB_PATH="${arg#--pml-lib=}" ;;
        --enable-asan)     ENABLE_ASAN="yes" ;;
        --disable-asan)    ENABLE_ASAN="no" ;;
        --help|-h)
            sed -n '2,8p' "$0"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            echo "Try './configure --help'"
            exit 1
            ;;
    esac
done

# ============================================================
# Build header test flags from C_INCLUDE_PATH + local include/
# ============================================================
HEADER_TEST_FLAGS="-I./include"
if [ -n "$C_INCLUDE_PATH" ]; then
    OLD_IFS="$IFS"
    IFS=":"
    for p in $C_INCLUDE_PATH; do
        [ -n "$p" ] && HEADER_TEST_FLAGS="$HEADER_TEST_FLAGS -I$p"
    done
    IFS="$OLD_IFS"
fi

# ============================================================
# Helper: test if a header file physically exists under any
# include search path.  Does NOT invoke the preprocessor, so
# transitive #include failures can never cause a false "no".
# ============================================================
test_header() {
    _header="$1"
    # Paths to search: explicit flags + gcc's own built-in paths
    _search_paths="./include"
    if [ -n "$C_INCLUDE_PATH" ]; then
        OLD_IFS="$IFS"; IFS=":"
        for p in $C_INCLUDE_PATH; do
            [ -n "$p" ] && _search_paths="$_search_paths $p"
        done
        IFS="$OLD_IFS"
    fi
    # Pull gcc's built-in system include paths
    _gcc_paths=$($CC -E -v - </dev/null 2>&1 \
        | awk '/#include <\.\.\.> search starts here:/{p=1;next} /End of search list/{p=0} p{print $1}')
    _search_paths="$_search_paths $_gcc_paths"

    for _dir in $_search_paths; do
        [ -n "$_dir" ] && [ -f "$_dir/$_header" ] && echo "yes" && return 0
    done
    echo "no"
}

# ============================================================
# Helper: find the directory that actually contains a header.
# Returns the first matching search-path directory, or empty.
# ============================================================
find_header_dir() {
    _header="$1"
    _search_paths="./include"
    if [ -n "$C_INCLUDE_PATH" ]; then
        OLD_IFS="$IFS"; IFS=":"
        for p in $C_INCLUDE_PATH; do
            [ -n "$p" ] && _search_paths="$_search_paths $p"
        done
        IFS="$OLD_IFS"
    fi
    _gcc_paths=$($CC -E -v - </dev/null 2>&1 \
        | awk '/#include <\.\.\.> search starts here:/{p=1;next} /End of search list/{p=0} p{print $1}')
    _search_paths="$_search_paths $_gcc_paths"

    for _dir in $_search_paths; do
        if [ -n "$_dir" ] && [ -f "$_dir/$_header" ]; then
            echo "$_dir"
            return 0
        fi
    done
}

# ============================================================
# Build system library search paths
# ============================================================
SYSTEM_LIB_PATHS=$(echo "$LD_LIBRARY_PATH:/usr/lib:/usr/local/lib:/usr/lib64:/usr/local/lib64:/lib:/lib64:/usr/lib/x86_64-linux-gnu" | tr ':' ' ' | tr -s ' ')

# ============================================================
# Library search helpers
# ============================================================
find_pml_so() {
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -d "$path" ]; then
            if [ -f "$path/libpml.so" ]; then echo "$path/libpml.so"; return 0; fi
            for f in "$path"/libpml.so.*; do
                if [ -f "$f" ]; then echo "$f"; return 0; fi
            done
        fi
    done
}

find_pml_a() {
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -f "$path/libpml.a" ]; then
            echo "$path/libpml.a"
            return 0
        fi
    done
}

check_pml_so() {
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -d "$path" ]; then
            if [ -f "$path/libpml.so" ]; then echo "yes"; return 0; fi
            for f in "$path"/libpml.so.*; do
                if [ -f "$f" ]; then echo "yes"; return 0; fi
            done
        fi
    done
    echo "no"
}

check_pml_a() {
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -f "$path/libpml.a" ]; then
            echo "yes"
            return 0
        fi
    done
    echo "no"
}

# ============================================================
# Run detection
# ============================================================
echo ""

# --- Compiler ---
printf "checking for C compiler... "
if command -v "$CC" >/dev/null 2>&1; then
    echo "$CC"
else
    echo "not found"
    echo "configure: error: C compiler '$CC' not found"
    exit 1
fi

# --- C_INCLUDE_PATH ---
if [ -n "$C_INCLUDE_PATH" ]; then
    printf "checking C_INCLUDE_PATH... "
    echo "$C_INCLUDE_PATH"
fi

# --- LD_LIBRARY_PATH ---
if [ -n "$LD_LIBRARY_PATH" ]; then
    printf "checking LD_LIBRARY_PATH... "
    echo "$LD_LIBRARY_PATH"
fi

# --- FLINT headers (required) ---
printf "checking for flint/flint.h... "
FLINT_HEADER_CHECK=$(test_header "flint/flint.h")
echo "$FLINT_HEADER_CHECK"

if [ "$FLINT_HEADER_CHECK" != "yes" ]; then
    echo "configure: error: FLINT headers not found!"
    echo "  Compiler cannot find flint/flint.h."
    echo "  Check C_INCLUDE_PATH or install FLINT development packages."
    rm -f "$TEMP_TEST_FILE"
    exit 1
fi

# --- FLINT include directory ---
printf "checking for FLINT include directory... "
FLINT_DIR_EXISTS="no"
if [ -d "$FLINT_INCLUDE_PATH" ]; then
    FLINT_DIR_EXISTS="yes"
    echo "$FLINT_INCLUDE_PATH"
else
    echo "not found at $FLINT_INCLUDE_PATH (using compiler search paths)"
fi

# --- PML headers ---
# Try flat layout first (pml.h), then pml/ subdirectory layout (pml/pml.h).
# All three headers must be consistently found under the same prefix.

printf "checking for pml.h... "
PML_HEADER_CHECK=$(test_header "pml.h")
if [ "$PML_HEADER_CHECK" = "yes" ]; then
    echo "yes"
    PML_HEADER_PREFIX=""
    # Record the directory that contains pml.h directly
    PML_HEADER_DIR=$(find_header_dir "pml.h")
else
    echo "no"
    printf "checking for pml/pml.h... "
    PML_SUB_CHECK=$(test_header "pml/pml.h")
    echo "$PML_SUB_CHECK"
    if [ "$PML_SUB_CHECK" = "yes" ]; then
        PML_HEADER_CHECK="yes"
        PML_HEADER_PREFIX="pml/"
        # The parent dir contains the pml/ subdirectory; headers inside it
        # use bare names (e.g. #include <nmod_poly_mat_utils.h>), so we need
        # to add <parent>/pml to the compiler include path.
        _pml_parent=$(find_header_dir "pml/pml.h")
        PML_HEADER_DIR="${_pml_parent}/pml"
    else
        PML_HEADER_PREFIX=""
        PML_HEADER_DIR=""
    fi
fi

printf "checking for ${PML_HEADER_PREFIX}nmod_poly_mat_utils.h... "
NMOD_POLY_MAT_UTILS_CHECK=$(test_header "${PML_HEADER_PREFIX}nmod_poly_mat_utils.h")
echo "$NMOD_POLY_MAT_UTILS_CHECK"

printf "checking for ${PML_HEADER_PREFIX}nmod_poly_mat_extra.h... "
NMOD_POLY_MAT_EXTRA_CHECK=$(test_header "${PML_HEADER_PREFIX}nmod_poly_mat_extra.h")
echo "$NMOD_POLY_MAT_EXTRA_CHECK"

# --- PML libraries ---
printf "checking for libpml.so... "
PML_DYNAMIC_LIB_CHECK=$(check_pml_so)
PML_SO_PATH=$(find_pml_so)
if [ "$PML_DYNAMIC_LIB_CHECK" = "yes" ]; then
    echo "$PML_SO_PATH"
else
    echo "no"
fi

printf "checking for libpml.a... "
PML_STATIC_LIB_CHECK=$(check_pml_a)
PML_A_PATH=$(find_pml_a)
if [ "$PML_STATIC_LIB_CHECK" = "yes" ]; then
    echo "$PML_A_PATH"
else
    echo "no"
fi

# --- PML include directory ---
printf "checking for PML include directory... "
PML_DIR_EXISTS="no"
if [ -d "$PML_INCLUDE_PATH" ]; then
    PML_DIR_EXISTS="yes"
    echo "$PML_INCLUDE_PATH"
else
    echo "not found at $PML_INCLUDE_PATH"
fi

# --- System libraries ---
printf "checking for -lmpfr... "
if [ "$(test_header mpfr.h)" = "yes" ]; then echo "yes"; else echo "no (continuing anyway)"; fi

printf "checking for -lgmp... "
if [ "$(test_header gmp.h)" = "yes" ]; then echo "yes"; else echo "no (continuing anyway)"; fi

# --- AddressSanitizer ---
ASAN_CFLAGS=""
ASAN_LDFLAGS=""
printf "checking whether to enable AddressSanitizer... "
if [ "$ENABLE_ASAN" = "yes" ]; then
    echo "yes"
    printf "checking for -fsanitize=address support... "
    _asan_tmp=".configure_asan_test.c"
    echo "int main(){return 0;}" > "$_asan_tmp"
    if $CC -fsanitize=address -static-libasan -o /dev/null "$_asan_tmp" >/dev/null 2>&1; then
        echo "yes"
        ASAN_CFLAGS="-fsanitize=address -static-libasan"
        ASAN_LDFLAGS="-fsanitize=address -static-libasan"
    elif $CC -fsanitize=address -o /dev/null "$_asan_tmp" >/dev/null 2>&1; then
        echo "yes (without static-libasan)"
        ASAN_CFLAGS="-fsanitize=address"
        ASAN_LDFLAGS="-fsanitize=address"
    else
        echo "no"
        echo "configure: warning: compiler does not support -fsanitize=address, ASan disabled"
        ENABLE_ASAN="no"
    fi
    rm -f "$_asan_tmp"
else
    echo "no (use --enable-asan to enable)"
fi

# ============================================================
# Determine PML availability
# ============================================================
echo ""
PML_AVAILABLE="no"
if [ "$PML_HEADER_CHECK" = "yes" ] && \
   [ "$NMOD_POLY_MAT_UTILS_CHECK" = "yes" ] && \
   [ "$NMOD_POLY_MAT_EXTRA_CHECK" = "yes" ] && \
   { [ "$PML_DYNAMIC_LIB_CHECK" = "yes" ] || [ "$PML_STATIC_LIB_CHECK" = "yes" ]; }; then
    PML_AVAILABLE="yes"
fi

if [ "$PML_AVAILABLE" = "yes" ]; then
    echo "*** PML library FOUND - will build with PML support ***"
else
    echo "*** PML library NOT FOUND - will build without PML support ***"
fi

# ============================================================
# Compute derived variables (mirrors original Makefile logic)
# ============================================================
# Include flags
INCLUDE_FLAGS="-I./include"
if [ -n "$C_INCLUDE_PATH" ]; then
    OLD_IFS="$IFS"
    IFS=":"
    for p in $C_INCLUDE_PATH; do
        [ -n "$p" ] && INCLUDE_FLAGS="$INCLUDE_FLAGS -I$p"
    done
    IFS="$OLD_IFS"
fi

# If PML headers live inside a pml/ subdirectory, the headers themselves
# use bare #include <nmod_poly_mat_utils.h> etc., so we must add the pml/
# directory itself (not just its parent) to the compiler search path.
# Example: headers at /usr/local/include/pml/pml.h
#   -> we add -I/usr/local/include/pml so bare includes resolve correctly.
if [ "$PML_AVAILABLE" = "yes" ] && [ -n "$PML_HEADER_PREFIX" ] && [ -n "$PML_HEADER_DIR" ]; then
    # Only add if not already covered by C_INCLUDE_PATH or gcc paths
    INCLUDE_FLAGS="$INCLUDE_FLAGS -I$PML_HEADER_DIR"
fi

# Preprocessor defines
FLINT_FLAGS="-DHAVE_FLINT"
PML_FLAGS=""
if [ "$PML_AVAILABLE" = "yes" ]; then
    PML_FLAGS="-DHAVE_PML"
fi

# PML linking
PML_LIBS=""
PML_STATIC_LIBS=""
if [ "$PML_AVAILABLE" = "yes" ]; then
    if [ -n "$PML_SO_PATH" ]; then
        PML_LIBS="$PML_SO_PATH"
    else
        PML_LIBS="-lpml"
    fi
    if [ -n "$PML_A_PATH" ]; then
        PML_STATIC_LIBS="$PML_A_PATH"
    else
        PML_STATIC_LIBS="$PML_LIB_PATH/libpml.a"
    fi
fi

# RPATH
RPATH_FLAGS="-Wl,-rpath,$FLINT_LIB_PATH -Wl,-rpath,."
if [ "$PML_AVAILABLE" = "yes" ]; then
    RPATH_FLAGS="$RPATH_FLAGS -Wl,-rpath,$PML_LIB_PATH"
fi

# ============================================================
# Write config.mk
# ============================================================
CONFIG_FILE="config.mk"
printf "creating %s... " "$CONFIG_FILE"

cat > "$CONFIG_FILE" << ENDOFCONFIG
# Generated by ./configure on $(date)
# Do not edit -- re-run ./configure instead.

# Compiler
CC = $CC

# Paths
FLINT_INCLUDE_PATH = $FLINT_INCLUDE_PATH
FLINT_LIB_PATH = $FLINT_LIB_PATH
PML_INCLUDE_PATH = $PML_INCLUDE_PATH
PML_LIB_PATH = $PML_LIB_PATH

# Detection results
FLINT_HEADER_CHECK = $FLINT_HEADER_CHECK
PML_HEADER_CHECK = $PML_HEADER_CHECK
PML_HEADER_PREFIX = $PML_HEADER_PREFIX
PML_HEADER_DIR = $PML_HEADER_DIR
NMOD_POLY_MAT_UTILS_CHECK = $NMOD_POLY_MAT_UTILS_CHECK
NMOD_POLY_MAT_EXTRA_CHECK = $NMOD_POLY_MAT_EXTRA_CHECK
PML_DYNAMIC_LIB_CHECK = $PML_DYNAMIC_LIB_CHECK
PML_STATIC_LIB_CHECK = $PML_STATIC_LIB_CHECK
PML_SO_PATH = $PML_SO_PATH
PML_A_PATH = $PML_A_PATH
FLINT_DIR_EXISTS = $FLINT_DIR_EXISTS
PML_DIR_EXISTS = $PML_DIR_EXISTS
PML_AVAILABLE = $PML_AVAILABLE

# System library search paths (for info/debug targets)
SYSTEM_LIB_PATHS = $SYSTEM_LIB_PATHS

# Derived flags
INCLUDE_FLAGS = $INCLUDE_FLAGS
FLINT_FLAGS = $FLINT_FLAGS
PML_FLAGS = $PML_FLAGS

# Library linking
FLINT_LIBS = -L$FLINT_LIB_PATH -lflint
FLINT_STATIC_LIBS = $FLINT_LIB_PATH/libflint.a
PML_LIBS = $PML_LIBS
PML_STATIC_LIBS = $PML_STATIC_LIBS
SYSTEM_LIBS = -lmpfr -lgmp -lm -lpthread -lstdc++

# RPATH
RPATH_FLAGS = $RPATH_FLAGS

# AddressSanitizer
ENABLE_ASAN = $ENABLE_ASAN
ASAN_CFLAGS = $ASAN_CFLAGS
ASAN_LDFLAGS = $ASAN_LDFLAGS
ENDOFCONFIG

echo "done"
echo "configure complete. Now run 'make'."
